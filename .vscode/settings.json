{
	"files.associations": {
		"**/*.json5": "json5"
	},
	"yaml.schemaStore.enable": true,
	"yaml.schemas": {
		"Kubernetes": "./kubernetes/**/*.yaml",
		"https://json.schemastore.org/github-workflow.json": "file://wsl.localhost/archlinux/home/tyler/git/home-ops/.github/workflows/image-pull.yaml"
	},
	"vs-kubernetes": {
		"vs-kubernetes.kubeconfig": "./kubeconfig",
		"vs-kubernetes.knownKubeconfigs": ["./kubeconfig"]
	},
	"prettier.singleQuote": true,
	"prettier.useTabs": true,
	"[just]": {
		"editor.defaultFormatter": "nefrob.vscode-just-syntax"
	},
	"[yaml]": {
		"editor.defaultFormatter": "oxc.oxc-vscode"
	},
	"[json]": {
		"editor.defaultFormatter": "oxc.oxc-vscode"
	},
	"[jsonc]": {
		"editor.defaultFormatter": "oxc.oxc-vscode"
	},
	"[json5]": {
		"editor.defaultFormatter": "oxc.oxc-vscode"
	},
	"[markdown]": {
		"editor.defaultFormatter": "oxc.oxc-vscode"
	}
}
